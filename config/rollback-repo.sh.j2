#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <date_tag>"
    echo "Example: $0 20260424"
    exit 1
fi

TARGET_DATE="$1"

{% set host_path = '' %}
{% for target_item in item.target %}
{% if target_item.host_path is defined %}
{% set host_path = target_item.host_path %}
{% endif %}
{% endfor %}

REPO_ROOT="{{ host_path }}"
TARGET_DIR="$REPO_ROOT/$TARGET_DATE"
LATEST_LINK="$REPO_ROOT/Latest"

if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: Directory $TARGET_DIR does not exist."
    exit 1
fi

echo "Rolling back {{ item.name }} to $TARGET_DATE..."

cd "$REPO_ROOT"
rm -f "$LATEST_LINK"
ln -s "$TARGET_DATE" "Latest"

echo "Rollback complete."
echo "Triggering signing script for the rolled-back repo..."
bash "{{ stack_path }}/nginx/config/sign-{{ item.name }}.sh"
