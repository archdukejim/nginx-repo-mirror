#!/usr/bin/env bash
# generate-gpg.sh - create a dedicated key for the mirrors
set -euo pipefail

# 1. Generate a new RSA key (2048-bit is sufficient for a private mirror)
cat >keyparams <<'EOF'
Key-Type: RSA
Key-Length: 2048
Subkey-Type: RSA
Subkey-Length: 2048
Name-Real: {{ kit_name | capitalize }} Internal Mirror
Name-Email: repo@{{ domain }}
Expire-Date: 0
%no-protection
%commit
EOF

gpg --batch --gen-key keyparams

# 2. Export the public key in binary format (the file that clients will download)
mkdir -p {{ stack_path }}/nginx/www/
gpg --output {{ stack_path }}/nginx/www/repo-key.gpg --export repo@{{ domain }}

# 3. Export the private key (used only for signing Release files – keep it safe)
mkdir -p {{ stack_path }}/nginx/secret/
gpg --output {{ stack_path }}/nginx/secret/repo-private.key --armor --export-secret-keys repo@{{ domain }}

# 4. Clean up temporary file
rm -f keyparams
