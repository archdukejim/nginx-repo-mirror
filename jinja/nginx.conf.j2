{% for repo in repos %}
server {
    listen 80;
    server_name {{ repo.fqdn }};

    # Serve the custom HTML landing page at the root
    location = / {
        root /usr/share/nginx/html/{{ repo.name }};
        index index.html;
    }

    # Serve the repository files
    location /{{ repo.name }}/ {
        alias /usr/share/nginx/html/{{ repo.name }}/Latest/;
        autoindex on;
        add_before_body /.assets/header.html;
    }

    # Shared assets for HTML pages
    location /.assets/ {
        alias /usr/share/nginx/html/.assets/;
    }
}
{% endfor %}
