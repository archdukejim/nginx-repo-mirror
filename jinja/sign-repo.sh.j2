#!/usr/bin/env bash
set -euo pipefail

# Find the host_path for this specific repo
{% set host_path = '' %}
{% for target_item in item.target %}
{% if target_item.host_path is defined %}
{% set host_path = target_item.host_path %}
{% endif %}
{% endfor %}

REPO_ROOT="{{ host_path }}/Latest"
GPG_KEY="repo@{{ domain }}"
GPG_OPTS="--default-key $GPG_KEY --batch --yes"

echo "Signing repository: {{ item.name }} at $REPO_ROOT"

if [ ! -d "$REPO_ROOT" ]; then
    echo "Error: Directory $REPO_ROOT does not exist."
    exit 1
fi

# Sign every Release file (including sub-dists like focal, bionic, etc.)
find "$REPO_ROOT" -type f -name Release -print0 | while IFS= read -r -d '' rel; do
    # Remove stale signatures
    rm -f "${rel}.gpg" "${rel}.asc" "${rel}.inrelease"

    # 1. Detached binary signature – Release.gpg
    gpg $GPG_OPTS --output "${rel}.gpg" --detach-sign "$rel"

    # 2. Clear-text (ASCII) signature – Release.asc (optional)
    gpg $GPG_OPTS --clearsign --output "${rel}.asc" "$rel"

    # 3. Clear-text signed Release – InRelease (preferred)
    gpg $GPG_OPTS --clearsign --output "${rel}.inrelease" "$rel"
    
    echo "Signed $rel"
done
