#!/usr/bin/env bash
set -euo pipefail

# Find host path and source info
{% set host_path = '' %}
{% for target_item in item.target %}
{% if target_item.host_path is defined %}
{% set host_path = target_item.host_path %}
{% endif %}
{% endfor %}

{% set source_uri = '' %}
{% set source_path = '' %}
{% for source_item in item.source %}
{% if source_item.uri is defined %}
{% set source_uri = source_item.uri %}
{% endif %}
{% if source_item.path is defined %}
{% set source_path = source_item.path %}
{% endif %}
{% endfor %}

REPO_ROOT="{{ host_path }}"
DATE_TAG=$(date +%Y%m%d)
CURRENT_SYNC_DIR="$REPO_ROOT/$DATE_TAG"
LATEST_LINK="$REPO_ROOT/Latest"

SOURCE_URL="rsync://${source_uri}/${source_path}/"
echo "Starting sync for {{ item.name }} from $SOURCE_URL"

mkdir -p "$REPO_ROOT"
cd "$REPO_ROOT"

# Find the most recent date folder to use as link-dest
PREV_DIR=$(find . -maxdepth 1 -type d -name "20*" | sort | tail -n 1 | sed 's|^\./||')

RSYNC_OPTS="-aHz --delete"
if [ -n "$PREV_DIR" ]; then
    echo "Found previous sync at $PREV_DIR, using for --link-dest"
    RSYNC_OPTS="$RSYNC_OPTS --link-dest=$REPO_ROOT/$PREV_DIR"
fi

echo "Running rsync to $CURRENT_SYNC_DIR..."
# Note: rsync might fail if the remote source is down, so we handle it gracefully.
rsync $RSYNC_OPTS "$SOURCE_URL" "$CURRENT_SYNC_DIR" || echo "Warning: rsync returned a non-zero exit code, some files may have failed."

# Generate manifest: package name, hash, and path
echo "Generating manifest for rollback purposes..."
cd "$CURRENT_SYNC_DIR"
# The manifest will look similar to ls -la output but with SHA256 hashes for files.
find . -type f -exec bash -c 'echo -n "$(ls -la "{}") | Hash: "; sha256sum "{}" | awk "{print \$1}"' \; > "$REPO_ROOT/manifest-${DATE_TAG}.txt"

cd "$REPO_ROOT"
echo "Updating Latest symlink..."
rm -f "$LATEST_LINK"
ln -s "$DATE_TAG" "Latest"

echo "Sync complete for {{ item.name }}."

# Trigger the signing process
echo "Triggering signing script..."
bash "{{ stack_path }}/nginx/config/sign-{{ item.name }}.sh"
